/**
 * @fileoverview Firestore Security Rules for PortfolioForge application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for user profiles and their associated projects.
 * Themes are publicly readable, but write access is not granted, as this area of the application is not editable by end users.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile data, accessible only to the user themselves.
 * - /users/{userId}/projects/{projectId}: Stores projects belonging to a user, accessible only to the user.
 * - /themes/{themeId}: Stores themes available for portfolios, publicly readable.
 *
 * Key Security Decisions:
 * - Users can only access their own profile data and projects.
 * - Listing of all users is disallowed.
 * - Themes are publicly readable to allow browsing available customizations.
 *
 * Denormalization for Authorization:
 * - UserProfile.id must match the {userId} in /users/{userId} to ensure consistent ownership.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user profile documents.
     * @path /users/{userId}
     * @allow (get) User with UID 'nZ5MseHSnydSAuGloEiZuB7jTvg1' can read their own profile.
     * @allow (create) User with UID 'nZ5MseHSnydSAuGloEiZuB7jTvg1' can create their own profile.
     * @allow (update) User with UID 'nZ5MseHSnydSAuGloEiZuB7jTvg1' can update their own profile.
     * @allow (delete) User with UID 'nZ5MseHSnydSAuGloEiZuB7jTvg1' can delete their own profile.
     * @deny (get) User with UID 'otherUserId' cannot read the profile of user 'nZ5MseHSnydSAuGloEiZuB7jTvg1'.
     * @deny (create) User with UID 'otherUserId' cannot create a profile for user 'nZ5MseHSnydSAuGloEiZuB7jTvg1'.
     * @deny (update) User with UID 'otherUserId' cannot update the profile of user 'nZ5MseHSnydSAuGloEiZuB7jTvg1'.
     * @deny (delete) User with UID 'otherUserId' cannot delete the profile of user 'nZ5MseHSnydSAuGloEiZuB7jTvg1'.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to project documents within a user's profile.
     * @path /users/{userId}/projects/{projectId}
     * @allow (get) User with UID 'nZ5MseHSnydSAuGloEiZuB7jTvg1' can read their own project.
     * @allow (create) User with UID 'nZ5MseHSnydSAuGloEiZuB7jTvg1' can create a project under their profile.
     * @allow (update) User with UID 'nZ5MseHSnydSAuGloEiZuB7jTvg1' can update their own project.
     * @allow (delete) User with UID 'nZ5MseHSnydSAuGloEiZuB7jTvg1' can delete their own project.
     * @deny (get) User with UID 'otherUserId' cannot read the project of user 'nZ5MseHSnydSAuGloEiZuB7jTvg1'.
     * @deny (create) User with UID 'otherUserId' cannot create a project for user 'nZ5MseHSnydSAuGloEiZuB7jTvg1'.
     * @deny (update) User with UID 'otherUserId' cannot update the project of user 'nZ5MseHSnydSAuGloEiZuB7jTvg1'.
     * @deny (delete) User with UID 'otherUserId' cannot delete the project of user 'nZ5MseHSnydSAuGloEiZuB7jTvg1'.
     * @principle Enforces document ownership for all operations on projects.
     */
    match /users/{userId}/projects/{projectId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userProfileId == userId;
      allow update: if isExistingOwner(userId) && resource.data.userProfileId == userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to theme documents.
     * @path /themes/{themeId}
     * @allow (get) Any user can read theme data.
     * @allow (list) Any user can list themes.
     * @deny (create) No user can create theme data.
     * @deny (update) No user can update theme data.
     * @deny (delete) No user can delete theme data.
     * @principle Themes are publicly readable, writes are disallowed.
     */
    match /themes/{themeId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
    }
  }
}