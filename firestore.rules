/**
 * @fileoverview Firestore Security Rules for PortfolioForge.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for user profiles and their associated projects.
 * Only authenticated users can access their own profiles and projects. Themes are publicly readable.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile data, accessible only to the user.
 * - /users/{userId}/projects/{projectId}: Stores projects belonging to a user, accessible only to the user.
 * - /themes/{themeId}: Stores themes, publicly readable.
 *
 * Key Security Decisions:
 * - User listing is implicitly denied.
 * - Themes are publicly readable to allow for easy browsing.
 * - All write operations are guarded by authentication checks to prevent unauthorized data modification.
 *
 * Denormalization for Authorization:
 * - UserProfile.id MUST match the {userId} path parameter. This is enforced on create and update.
 * - Project.userProfileId MUST match the {userId} path parameter. This is enforced on create.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Rules for user profiles. Only the authenticated user can access their own profile.
     * @path /users/{userId}
     * @allow (create) - User with UID 'user123' can create a profile at /users/user123 if the document.id matches the UID.
     * @allow (get, update, delete, list) - User with UID 'user123' can read, update, or delete their profile at /users/user123.
     * @deny (create) - User with UID 'user456' cannot create a profile at /users/user123.
     * @deny (get, update, delete) - User with UID 'user456' cannot read, update, or delete the profile at /users/user123.
     * @principle Enforces document ownership for writes and restricts access to a user's own data tree.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
          return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for projects associated with a user profile. Only the authenticated user can access their own projects.
     * @path /users/{userId}/projects/{projectId}
     * @allow (create) - User 'user123' can create a project under /users/user123/projects/project1 if project.userProfileId matches 'user123'.
     * @allow (get, update, delete, list) - User 'user123' can read, update, or delete their projects under /users/user123/projects/{projectId}.
     * @deny (create) - User 'user456' cannot create a project under /users/user123/projects/project1.
     * @deny (get, update, delete) - User 'user456' cannot read, update, or delete projects under /users/user123/projects/{projectId}.
     * @principle Enforces document ownership for writes and restricts access to a user's own data tree.
     */
    match /users/{userId}/projects/{projectId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
          return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userProfileId == userId;
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for themes. Accessible to all users to view themes.
     * @path /themes/{themeId}
     * @allow (get, list) - Any user can read themes.
     * @deny (create, update, delete) - No user can create, update, or delete themes.
     * @principle Allows public read access for themes.
     */
    match /themes/{themeId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }
  }
}