
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // By default, require users to be authenticated.
    // We are more permissive in this prototype to allow for anonymous users and to
    // simplify the backend logic. In a production app, you would want to add
    // more robust security rules here.
    match /{document=**} {
      allow read, write: if true;
    }

    // To demonstrate saving data from a backend, we will make the `cvData`
    // collection world-writeable. This is NOT secure and should not be used in
    // a production environment. In a real-world application, you would want to
    // use a secure method to authenticate your backend and only allow it to
    // write to specific documents.
    match /cvData/{userId} {
      allow read, write: if true;
    }
  }
}
