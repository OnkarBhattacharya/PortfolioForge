/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict user-ownership model for user profiles and projects,
 *              while allowing public read access to themes.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile data. Only the user can read/write their own profile.
 * - /users/{userId}/projects/{projectId}: Stores projects associated with a specific user. Only the user can read/write their own projects.
 * - /themes/{themeId}: Stores themes available for portfolios. Publicly readable.
 *
 * Key Security Decisions:
 * - User profiles and projects are strictly controlled by their owners. No listing of users is allowed.
 * - Themes are publicly readable.
 *
 * Denormalization for Authorization:
 *  - The `userProfileId` field on `/users/{userId}/projects/{projectId}` documents is used to ensure
 *    that projects belong to the correct user, avoiding the need for complex `get()` calls.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Protects user profile data, ensuring only the authenticated user can access their own profile.
     * @path /users/{userId}
     * @allow (get, create, update, delete) - Authenticated user with matching userId.
     * @deny (get, create, update, delete) - Any other user or unauthenticated user.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return isSignedIn() && request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Protects projects associated with a specific user, ensuring only the user can access their own projects.
     * @path /users/{userId}/projects/{projectId}
     * @allow (get, create, update, delete) - Authenticated user with matching userId and project.userProfileId.
     * @deny (get, create, update, delete) - Any other user or unauthenticated user.
     * @principle Enforces document ownership for writes and validates the relationship between user and project.
     */
    match /users/{userId}/projects/{projectId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return isSignedIn() && request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userProfileId == userId;
      allow update: if isExistingOwner(userId) && resource.data.userProfileId == userId;
      allow delete: if isExistingOwner(userId) && resource.data.userProfileId == userId;
    }

    /**
     * @description Allows public read access to themes.
     * @path /themes/{themeId}
     * @allow (get, list) - Any user, authenticated or not.
     * @deny (create, update, delete) - Any user.
     * @principle Allows public read access to themes while restricting write access.
     */
    match /themes/{themeId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
    
    /**
     * @description Protects cvData, ensuring only the authenticated user can access their own cvData.
     * @path /cvData/{userId}
     * @allow (get, create, update, delete) - Authenticated user with matching userId.
     * @deny (get, create, update, delete) - Any other user or unauthenticated user.
     * @principle Enforces document ownership for writes.
     */
    match /cvData/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return isSignedIn() && request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }
  }
}