/**
 * @file Firestore Security Rules for PortfolioForge
 * @description This ruleset enforces a strict user-ownership model for user profiles, projects, and portfolios. Themes are publicly readable.
 *
 * Data Structure:
 * - /users/{userId}/profile: User profile data, accessible only by the user.
 * - /users/{userId}/projects/{projectId}: Projects owned by a user, accessible only by the user.
 * - /users/{userId}/portfolio: Portfolio data for a user, accessible only by the user.
 * - /themes/{themeId}: Publicly readable themes.
 *
 * Key Security Decisions:
 * - Users can only access their own data (profile, projects, portfolio).
 * - Themes are publicly readable.
 * - User listing is not allowed.
 *
 * Denormalization for Authorization:
 * - The rules rely on the path-based userId to authorize access to user-specific data.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Secure access to user profiles. Only the user can read/write their own profile.
     * @path /users/{userId}/profile
     * @allow (create) User with ID 'user123' creates their profile. request.auth.uid == 'user123'
     * @deny (create) User with ID 'user123' tries to create profile for 'user456'. request.auth.uid != 'user123'
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId}/profile {
      // Users can only read/write their own profile
      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false; // Listing profiles is not allowed.
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isExistingOwner(userId);
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }

    /**
     * @description Secure access to user projects. Only the user can read/write their own projects.
     * @path /users/{userId}/projects/{projectId}
     * @allow (create) User with ID 'user123' creates a project under their user ID. request.auth.uid == 'user123'
     * @deny (create) User with ID 'user123' tries to create a project under 'user456'. request.auth.uid != 'user123'
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId}/projects/{projectId} {
      // Users can only read/write their own projects
      allow get: if isSignedIn() && isOwner(userId);
      allow list: if isSignedIn() && isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId) ;
      allow update: if isSignedIn() && isExistingOwner(userId);
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }

     /**
      * @description Secure access to user portfolio. Only the user can read/write their own portfolio.
      * @path /users/{userId}/portfolio
      * @allow (create) User with ID 'user123' creates their portfolio. request.auth.uid == 'user123'
      * @deny (create) User with ID 'user123' tries to create portfolio for 'user456'. request.auth.uid != 'user123'
      * @principle Enforces document ownership for writes.
      */
    match /users/{userId}/portfolio {
      // Users can only read/write their own portfolio
      allow get: if isSignedIn() && isOwner(userId);
      allow list: if isSignedIn() && isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isExistingOwner(userId);
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }

    /**
     * @description Allow public read access to themes.
     * @path /themes/{themeId}
     * @allow (get) Any user can get a theme.
     * @allow (list) Any user can list themes.
     * @deny (create) No one can create themes through the client.
     * @deny (update) No one can update themes through the client.
     * @deny (delete) No one can delete themes through the client.
     */
    match /themes/{themeId} {
      // Themes are publicly readable, but not writable
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // --- Helper functions ---

    // Check if the user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Check if the user is the owner of the resource
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    //Check if the user is the owner of existing resource
    function isExistingOwner(userId) {
        return isSignedIn() && isOwner(userId) && resource != null;
    }
  }
}