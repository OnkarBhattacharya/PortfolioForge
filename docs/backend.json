
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile in the PortfolioForge application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the UserProfile entity."
        },
        "firstName": {
          "type": "string",
          "description": "User's first name."
        },
        "lastName": {
          "type": "string",
          "description": "User's last name."
        },
        "email": {
          "type": "string",
          "description": "User's email address.",
          "format": "email"
        },
        "linkedInUrl": {
          "type": "string",
          "description": "URL to the user's LinkedIn profile.",
          "format": "uri"
        },
        "githubUrl": {
          "type": "string",
          "description": "URL to the user's GitHub profile.",
          "format": "uri"
        },
        "customDomain": {
          "type": "string",
          "description": "The custom domain connected to the user's portfolio, if any.",
          "format": "uri"
        },
        "themeId": {
          "type": "string",
          "description": "The ID of the selected theme for the user's portfolio."
        }
      },
      "required": [
        "id",
        "email"
      ]
    },
    "Project": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Project",
      "type": "object",
      "description": "Represents a project showcased in the user's portfolio, sourced from GitHub or Firebase.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Project entity."
        },
        "userProfileId": {
          "type": "string",
          "description": "Reference to UserProfile. (Relationship: UserProfile 1:N Project)"
        },
        "name": {
          "type": "string",
          "description": "Name of the project."
        },
        "description": {
          "type": "string",
          "description": "Description of the project."
        },
        "imageId": {
          "type": "string",
          "description": "ID of the placeholder image for the project."
        },
        "projectUrl": {
          "type": "string",
          "description": "URL to the live project or GitHub repository.",
          "format": "uri"
        },
        "source": {
          "type": "string",
          "description": "Source of the project (e.g., 'GitHub', 'Firebase')."
        }
      },
      "required": [
        "id",
        "userProfileId",
        "name",
        "description",
        "source"
      ]
    },
    "Theme": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Theme",
      "type": "object",
      "description": "Represents a theme available for portfolio customization.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Theme entity."
        },
        "name": {
          "type": "string",
          "description": "Name of the theme."
        },
        "description": {
          "type": "string",
          "description": "Description of the theme."
        },
        "previewImageUrl": {
          "type": "string",
          "description": "URL to a preview image of the theme.",
          "format": "uri"
        },
        "price": {
          "type": "number",
          "description": "Price of the theme."
        },
        "isPremium": {
          "type": "boolean",
          "description": "Whether the theme is a premium theme."
        }
      },
      "required": [
        "id",
        "name",
        "description",
        "previewImageUrl"
      ]
    },
    "Portfolio": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Portfolio",
      "type": "object",
      "description": "Represents a user's portfolio, linking user profile and selected theme.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Portfolio entity."
        },
        "userProfileId": {
          "type": "string",
          "description": "Reference to UserProfile. (Relationship: UserProfile 1:1 Portfolio)"
        },
        "themeId": {
          "type": "string",
          "description": "Reference to Theme. (Relationship: Theme 1:1 Portfolio)"
        },
        "customizations": {
          "type": "string",
          "description": "JSON string storing custom theme customizations."
        }
      },
      "required": [
        "id",
        "userProfileId",
        "themeId"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": {
            "$ref": "#/entities/UserProfile"
          },
          "description": "Stores user profile data. Only the user can read/write their own profile."
        }
      },
      {
        "path": "/users/{userId}/projects/{projectId}",
        "definition": {
          "entityName": "Project",
          "schema": {
            "$ref": "#/entities/Project"
          },
          "description": "Stores projects associated with a specific user. Only the user can read/write their own projects."
        }
      },
      {
        "path": "/themes/{themeId}",
        "definition": {
          "entityName": "Theme",
          "schema": {
            "$ref": "#/entities/Theme"
          },
          "description": "Stores themes available for portfolios. Publicly readable."
        }
      }
    ]
  }
}
