
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile in the PortfolioForge application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the UserProfile entity."
        },
        "fullName": {
          "type": "string",
          "description": "User's full name."
        },
        "email": {
          "type": "string",
          "description": "User's email address.",
          "format": "email"
        },
        "role": {
          "type": "string",
          "description": "The user's role in the system.",
          "enum": ["user", "admin"]
        },
        "linkedInUrl": {
          "type": "string",
          "description": "URL to the user's LinkedIn profile.",
          "format": "uri"
        },
        "githubUrl": {
          "type": "string",
          "description": "URL to the user's GitHub profile.",
          "format": "uri"
        },
        "customDomain": {
          "type": "string",
          "description": "The custom domain connected to the user's portfolio, if any.",
          "format": "hostname"
        },
        "customDomainStatus": {
            "type": "string",
            "description": "The verification status of the custom domain.",
            "enum": ["pending", "active", "error"]
        },
        "themeId": {
          "type": "string",
          "description": "The ID of the selected theme for the user's portfolio."
        },
        "subscriptionTier": {
          "type": "string",
          "description": "The user's current subscription tier.",
          "enum": ["free", "pro"]
        },
        "subscriptionStatus": {
          "type": "string",
          "description": "The status of the user's subscription.",
          "enum": ["active", "canceled", "past_due"]
        },
        "subscriptionPeriodEndDate": {
          "type": "string",
          "description": "The end date of the current subscription period.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "email",
        "fullName"
      ]
    },
    "PortfolioItem": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "PortfolioItem",
      "type": "object",
      "description": "Represents a generic item in a user's portfolio, such as a project, case study, or artwork.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the PortfolioItem entity."
        },
        "userProfileId": {
          "type": "string",
          "description": "Reference to UserProfile. (Relationship: UserProfile 1:N PortfolioItem)"
        },
        "name": {
          "type": "string",
          "description": "Name of the portfolio item."
        },
        "description": {
          "type": "string",
          "description": "Description of the portfolio item."
        },
        "imageId": {
          "type": "string",
          "description": "ID of the placeholder image for the item."
        },
        "itemUrl": {
          "type": "string",
          "description": "URL to the live item, case study, or source code.",
          "format": "uri"
        },
        "tags": {
          "type": "array",
          "description": "A list of tags, skills, or technologies associated with the item.",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "id",
        "userProfileId",
        "name",
        "description"
      ]
    },
    "Theme": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Theme",
      "type": "object",
      "description": "Represents a theme available for portfolio customization.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Theme entity."
        },
        "name": {
          "type": "string",
          "description": "Name of the theme."
        },
        "description": {
          "type": "string",
          "description": "Description of the theme."
        },
        "previewImageUrl": {
          "type": "string",
          "description": "URL to a preview image of the theme.",
          "format": "uri"
        },
        "price": {
          "type": "number",
          "description": "Price of the theme."
        },
        "isPremium": {
          "type": "boolean",
          "description": "Whether the theme is a premium theme."
        }
      },
      "required": [
        "id",
        "name",
        "description",
        "previewImageUrl"
      ]
    },
    "Portfolio": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Portfolio",
      "type": "object",
      "description": "Represents a user's portfolio, linking user profile and selected theme.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Portfolio entity."
        },
        "userProfileId": {
          "type": "string",
          "description": "Reference to UserProfile. (Relationship: UserProfile 1:1 Portfolio)"
        },
        "themeId": {
          "type": "string",
          "description": "Reference to Theme. (Relationship: Theme 1:1 Portfolio)"
        },
        "customizations": {
          "type": "string",
          "description": "JSON string storing custom theme customizations."
        }
      },
      "required": [
        "id",
        "userProfileId",
        "themeId"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": {
            "$ref": "#/entities/UserProfile"
          },
          "description": "Stores user profile data. Only the user can read/write their own profile."
        }
      },
      {
        "path": "/users/{userId}/portfolioItems/{itemId}",
        "definition": {
          "entityName": "PortfolioItem",
          "schema": {
            "$ref": "#/entities/PortfolioItem"
          },
          "description": "Stores portfolio items associated with a specific user. Only the user can read/write their own items."
        }
      },
      {
        "path": "/themes/{themeId}",
        "definition": {
          "entityName": "Theme",
          "schema": {
            "$ref": "#/entities/Theme"
          },
          "description": "Stores themes available for portfolios. Publicly readable."
        }
      }
    ]
  }
}
