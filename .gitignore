# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencies & Build Outputs
/node_modules
/.next/
/out/
/build
.pnp
.pnp.js
next-env.d.ts
.next_old

# Testing
/coverage

# Firebase
# NEVER commit service account keys
serviceAccountKey.json
# Ignore Firebase Hosting and emulators cache/logs
.firebase/
firebase-debug.log
database-debug.log
firestore-debug.log
pubsub-debug.log
storage-debug.log
firebaserc.json

# Local Environment Variables
# Contains sensitive API keys and secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE & Editor Directories
.idea/
.vscode/
.idx/
*.swp
*.swo

# OS-generated files
.DS_Store
Thumbs.db

# Misc
*.pem

# Test tool
playwright.config.ts
